# Copie este arquivo para .env e preencha com os dados do seu projeto Supabase.
# Painel Supabase: Settings > API

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-public-key-aqui

# (Opcional, só para rodar migrações localmente via scripts/db.mjs)
# Connection string do Postgres (Settings > Database > Session pooler).
# É um SEGREDO forte — fica só no .env local (gitignored), nunca no chat/git.
# SUPABASE_DB_URL=postgresql://postgres.xxxx:SENHA@aws-0-...pooler.supabase.com:5432/postgres
